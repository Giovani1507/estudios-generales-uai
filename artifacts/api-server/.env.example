# Copia este archivo a .env y ajusta los valores.
PORT=8080
NODE_ENV=development

# PostgreSQL local (ajusta usuario/contraseña si instalaste otro)
DATABASE_URL=postgresql://postgres:TU_PASSWORD@localhost:5432/estudios_generales

# Opcional: sincronización con intranet UAI
# INTRANET_USERNAME=
# INTRANET_PASSWORD=
# INTRANET_COOKIE=
# INTRANET_TERM_ID=

# Opcional: correo (Office 365)
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_EMAIL=
# SMTP_PASSWORD=
